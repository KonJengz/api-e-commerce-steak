# Public API domain that will point to the Droplet.
API_HOSTNAME=api.example.com
# Email used by Caddy for ACME / Let's Encrypt registration.
ACME_EMAIL=ops@example.com

# Runtime
APP_ENV=production
LOG_JSON=true
TRUST_PROXY_HEADERS=true
CLEANUP_INTERVAL_MINUTES=10
PRODUCT_IMAGE_UPLOAD_TTL_MINUTES=60

# Database
# Prefer the Neon pooled URL for the running API. Keep DATABASE_URL for compatibility if needed.
DATABASE_URL=
DATABASE_URL_DIRECT=
DATABASE_URL_POOLED=
DATABASE_MAX_CONNECTIONS=10
DATABASE_ACQUIRE_TIMEOUT_SECONDS=30

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# App
# This is the frontend origin allowed by CORS, not the API hostname above.
APP_URL=https://app.example.com
COOKIE_SECURE=true

# Social Login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
