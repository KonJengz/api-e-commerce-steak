# Runtime
APP_ENV=development
LOG_JSON=false
TRUST_PROXY_HEADERS=false
CLEANUP_INTERVAL_MINUTES=10
PRODUCT_IMAGE_UPLOAD_TTL_MINUTES=60

# Database
DATABASE_URL=postgres://user:password@localhost:5432/ecommerce
# Optional for Neon or other providers with separate direct/pooled URLs
DATABASE_URL_DIRECT=
DATABASE_URL_POOLED=
DATABASE_MAX_CONNECTIONS=10
DATABASE_ACQUIRE_TIMEOUT_SECONDS=30

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Email (Resend)
RESEND_API_KEY=re_123456789
EMAIL_FROM=noreply@yourdomain.com

# App
APP_URL=http://localhost:3000
# Optional locally. Platforms like DigitalOcean App Platform inject PORT automatically.
APP_PORT=4000
COOKIE_SECURE=false

# Social Login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
